---
import EpisodeArt from './EpisodeArt.astro';
import { formatDateShort, formatDuration, type Episode } from '../lib/feed';

interface Props {
  episode: Episode;
}
const { episode } = Astro.props;
---
<article class="ep">
  <a href={`/episodes/${episode.slug}/`} aria-label={episode.title}>
    <EpisodeArt num={episode.num} />
  </a>
  <div>
    <h3 class="title"><a href={`/episodes/${episode.slug}/`}>{episode.title}</a></h3>
    <p class="sub">{episode.summary.length > 220 ? episode.summary.slice(0, 220).trimEnd() + '…' : episode.summary}</p>
  </div>
  <span class="mono-meta">{formatDateShort(episode.date)} · {formatDuration(episode.duration)}</span>
</article>

<style>
  .ep {
    display: grid;
    grid-template-columns: 88px 1fr auto;
    gap: var(--sp-lg);
    align-items: center;
    padding: 18px 0;
    border-top: 1px solid var(--hairline);
  }
  .title {
    font-size: 21px;
    font-weight: 600;
    letter-spacing: 0.01em;
    line-height: 1.3;
  }
  .title a { color: var(--ink); text-decoration: none; transition: color 0.2s ease; }
  .title a:hover { color: var(--accent); }
  .sub {
    font-size: 15px;
    color: var(--muted);
    margin-top: 6px;
    max-width: 62ch;
  }
  @media (max-width: 640px) {
    .ep { grid-template-columns: 64px 1fr; }
    .ep > .mono-meta { grid-column: 2; }
  }
</style>
